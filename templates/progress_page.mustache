{{!
    @template local_vbs_myoverview/progress_page

    F02 learning-progress page shell. Each section starts as a skeleton loader;
    the local_vbs_myoverview/progress AMD module replaces the [data-region="body"]
    of each section once its data resolves (independently — TC-19).

    Context variables required for this template:
    * year int Current year, used in the plan section heading.

    Example context (json):
    {
        "year": 2026
    }
}}
<div class="vbs-lp" data-region="learning-progress">

    <section class="vbs-lp-section" data-region="section" data-section="plan"
             aria-labelledby="vbs-lp-plan-heading" aria-busy="true">
        <h3 id="vbs-lp-plan-heading" class="vbs-lp-section-title">
            {{#str}} progress:section_plan, local_vbs_myoverview, {{year}} {{/str}}
        </h3>
        <div data-region="body">
            {{> local_vbs_myoverview/progress_skeleton }}
        </div>
    </section>

    <section class="vbs-lp-section" data-region="section" data-section="active"
             aria-labelledby="vbs-lp-active-heading" aria-busy="true">
        <h3 id="vbs-lp-active-heading" class="vbs-lp-section-title">
            {{#str}} progress:section_active, local_vbs_myoverview {{/str}}
        </h3>
        <div data-region="body">
            {{> local_vbs_myoverview/progress_skeleton }}
        </div>
    </section>

    <section class="vbs-lp-section" data-region="section" data-section="completed"
             aria-labelledby="vbs-lp-completed-heading" aria-busy="true">
        <h3 id="vbs-lp-completed-heading" class="vbs-lp-section-title">
            {{#str}} progress:section_completed, local_vbs_myoverview {{/str}}
        </h3>
        <div data-region="body">
            {{> local_vbs_myoverview/progress_skeleton }}
        </div>
    </section>

    <section class="vbs-lp-section" data-region="section" data-section="certificates"
             aria-labelledby="vbs-lp-cert-heading" aria-busy="true">
        <h3 id="vbs-lp-cert-heading" class="vbs-lp-section-title">
            {{#str}} progress:section_certificates, local_vbs_myoverview {{/str}}
        </h3>
        <div data-region="body">
            {{> local_vbs_myoverview/progress_skeleton }}
        </div>
    </section>

</div>
