{{!
    @template local_vbs_myoverview/progress_section_certificates

    "Issued certificates" section body (AC-06). The download control carries the
    BE-provided download_url (already contains downloadown=1); the AMD module
    intercepts the click and streams the PDF via a hidden iframe so the browser
    downloads in place — no navigation, no new tab (TC-18).

    Example context (json):
    {
        "hasany": true,
        "certs": [
            {"certname": "Occupational safety certificate",
             "download_url": "https://lms/mod/customcert/view.php?id=3&downloadown=1",
             "downloadlabel": "Download PDF", "downloadaria": "Download PDF of certificate ..."}
        ],
        "emptytext": "No certificates have been issued yet."
    }
}}
{{#hasany}}
    <ul class="vbs-lp-cert-list list-unstyled">
        {{#certs}}
            <li class="vbs-lp-cert">
                <span class="vbs-lp-cert-name">{{certname}}</span>
                <a href="{{download_url}}" class="btn btn-primary btn-sm vbs-lp-download"
                   data-action="download-cert" aria-label="{{downloadaria}}" download>
                    {{downloadlabel}}
                </a>
            </li>
        {{/certs}}
    </ul>
{{/hasany}}
{{^hasany}}
    <p class="vbs-lp-empty">{{emptytext}}</p>
{{/hasany}}
