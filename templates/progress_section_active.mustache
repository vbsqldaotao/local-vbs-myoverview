{{!
    @template local_vbs_myoverview/progress_section_active

    "Courses in progress" section body (AC-01). Progress bar width tracks
    completion_percent; deadline is pre-formatted dd/mm/yyyy in the user's
    timezone; delivery_mode is pre-mapped to a human label.

    Example context (json):
    {
        "hasany": true,
        "courses": [
            {"coursename": "Basic accounting", "courseurl": "https://lms/course/view.php?id=10",
             "percent": 65, "percentlabel": "65%", "barlabel": "Completion 65%",
             "deadlinetext": "Due: 01/10/2026", "deliverylabel": "E-learning"}
        ],
        "emptytext": "You have no courses in progress."
    }
}}
{{#hasany}}
    <ul class="vbs-lp-course-list list-unstyled">
        {{#courses}}
            <li class="vbs-lp-course">
                <a href="{{courseurl}}" class="vbs-lp-course-name">{{coursename}}</a>
                <div class="vbs-lp-course-meta">
                    <div class="progress vbs-lp-progress" role="progressbar"
                         aria-valuenow="{{percent}}" aria-valuemin="0" aria-valuemax="100"
                         aria-label="{{barlabel}}">
                        <div class="progress-bar bg-primary" style="width: {{percent}}%;"></div>
                    </div>
                    <span class="vbs-lp-percent">{{percentlabel}}</span>
                    <span class="vbs-lp-deadline">{{deadlinetext}}</span>
                    <span class="badge badge-info vbs-lp-delivery">{{deliverylabel}}</span>
                </div>
            </li>
        {{/courses}}
    </ul>
{{/hasany}}
{{^hasany}}
    <p class="vbs-lp-empty">{{emptytext}}</p>
{{/hasany}}
