{{!
    @template local_vbs_myoverview/progress_skeleton

    Per-section skeleton placeholder shown while a section loads (TC-19). It is
    aria-hidden and carries an sr-only "loading" label so screen readers announce
    progress without reading the shimmer rows. No context variables.

    Example context (json):
    {
    }
}}
<div class="vbs-lp-skeleton" data-region="skeleton">
    <span class="sr-only">{{#str}} progress:loading, local_vbs_myoverview {{/str}}</span>
    <div class="vbs-lp-skel-row vbs-lp-skel-lg" aria-hidden="true"></div>
    <div class="vbs-lp-skel-row" aria-hidden="true"></div>
    <div class="vbs-lp-skel-row vbs-lp-skel-sm" aria-hidden="true"></div>
</div>
