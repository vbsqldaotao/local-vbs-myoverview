{{!
    @template local_vbs_myoverview/progress_section_plan

    Training-plan section body. Rendered client-side by the progress AMD module,
    which pre-resolves every label and formats the dates. All dynamic text is
    already localised in the context — this template only lays it out.

    Example context (json):
    {
        "hasplan": true,
        "percent": 38,
        "countlabel": "3/8 items",
        "barlabel": "3 of 8 items completed",
        "hasitems": true,
        "items": [
            {"coursename": "Basic accounting", "statuslabel": "In progress",
             "statusclass": "badge-warning", "duetext": "01/10/2026"}
        ],
        "emptytext": "No training plan for 2026."
    }
}}
{{#hasplan}}
    <div class="vbs-lp-plan-summary">
        <div class="progress vbs-lp-progress" role="progressbar"
             aria-valuenow="{{percent}}" aria-valuemin="0" aria-valuemax="100"
             aria-label="{{barlabel}}">
            <div class="progress-bar bg-primary" style="width: {{percent}}%;"></div>
        </div>
        <span class="vbs-lp-plan-count">{{countlabel}}</span>
    </div>
    {{#hasitems}}
        <ul class="vbs-lp-plan-list list-unstyled">
            {{#items}}
                <li class="vbs-lp-plan-item">
                    <span class="vbs-lp-item-name">{{coursename}}</span>
                    <span class="badge {{statusclass}} vbs-lp-plan-status">{{statuslabel}}</span>
                    <span class="vbs-lp-item-due">{{duetext}}</span>
                </li>
            {{/items}}
        </ul>
    {{/hasitems}}
    {{^hasitems}}
        <p class="vbs-lp-empty">{{emptytext}}</p>
    {{/hasitems}}
{{/hasplan}}
{{^hasplan}}
    <p class="vbs-lp-empty">{{emptytext}}</p>
{{/hasplan}}
